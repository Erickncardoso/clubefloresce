DATABASE_URL="postgresql://user:password@localhost:5432/clubeflorescer"

# Cloudinary (uploads de imagem/vídeo/PDF)
# Coolify: configure no serviço do BACKEND (apiclube), NÃO no app cliente/PWA.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Limite de vídeo no multer (MB). Proxy/nginx precisa aceitar o mesmo tamanho.
# VIDEO_UPLOAD_MAX_SIZE_MB=2048
# Timeout do servidor Node para uploads longos (ms)
# UPLOAD_SERVER_TIMEOUT_MS=1800000

# JWT
JWT_SECRET=
PORT=3001

# CORS (opcional — se definir, mescla com os domínios padrão de produção)
# CORS_ORIGINS=https://clube.nutrisabellajardim.com.br

# OpenAI (Bella IA) — https://platform.openai.com/api-keys
# Coolify: configure no serviço do BACKEND (apiclube), NÃO no app cliente/PWA.
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_PDF=gpt-4o
# BELLA_DEBUG=true

# UazAPI (WhatsApp) — opcional
UAZAPI_SERVER_URL=
UAZAPI_API_KEY=

# Redis — opcional
REDIS_URL=
