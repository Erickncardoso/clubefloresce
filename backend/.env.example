DATABASE_URL="postgresql://user:password@localhost:5432/clubeflorescer"

# Cloudinary (uploads de imagem — e vídeo/PDF enquanto MEDIA_*_PROVIDER=cloudinary)
# Coolify: configure no serviço do BACKEND (apiclube), NÃO no app cliente/PWA.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Providers de mídia: cloudinary | bunny
# MEDIA_VIDEO_PROVIDER=cloudinary
# MEDIA_DOCUMENT_PROVIDER=cloudinary

# Bunny Stream (vídeos de aula) — quando MEDIA_VIDEO_PROVIDER=bunny
# BUNNY_STREAM_LIBRARY_ID=
# BUNNY_STREAM_API_KEY=
# BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
# BUNNY_STREAM_COLLECTION_ID=
# BUNNY_TRANSCRIPTION_LANG=pt
# Cache Redis dos metadados de vídeo (capítulos, sprites) — requer REDIS_URL
# BUNNY_METADATA_CACHE_TTL_SECONDS=21600

# Bunny Storage (PDFs/ebooks) — quando MEDIA_DOCUMENT_PROVIDER=bunny
# BUNNY_STORAGE_ZONE_NAME=
# BUNNY_STORAGE_API_KEY=
# BUNNY_STORAGE_CDN_HOSTNAME=xxxxx.b-cdn.net
# BUNNY_STORAGE_REGION=de
# BUNNY_STORAGE_DOCUMENTS_PREFIX=ebooks
# Por padrão PDFs abrem via proxy da API (BUNNY_STORAGE_USE_CDN=true só se o Pull Zone CDN estiver ativo)
# BACKEND_PUBLIC_URL=https://sua-api.exemplo.com
# DOCUMENT_UPLOAD_MAX_MB=100

# Limite de vídeo no multer (MB). Proxy/nginx precisa aceitar o mesmo tamanho.
# VIDEO_UPLOAD_MAX_SIZE_MB=2048
# Timeout do servidor Node para uploads longos (ms)
# UPLOAD_SERVER_TIMEOUT_MS=1800000

# JWT
JWT_SECRET=
PORT=3001

# CORS (opcional — se definir, mescla com os domínios padrão de produção)
# CORS_ORIGINS=https://clube.nutrisabellajardim.com.br

# OpenAI (Bella IA) — https://platform.openai.com/api-keys
# Coolify: configure no serviço do BACKEND (apiclube), NÃO no app cliente/PWA.
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_PDF=gpt-4o
# BELLA_DEBUG=true

# UazAPI (WhatsApp) — opcional
UAZAPI_SERVER_URL=
UAZAPI_API_KEY=
# Secret para validar POST /api/whatsapp/webhook (header x-webhook-secret)
WHATSAPP_WEBHOOK_SECRET=

# Chave obrigatória em produção para POST /api/auth/setup/nutricionista (header x-setup-key)
NUTRI_SETUP_KEY=

# Redis — opcional (cache de metadados Bunny Stream)
REDIS_URL=
