DATABASE_URL="postgresql://user:password@localhost:5432/clubeflorescer"

# Cloudinary (uploads de imagem — e vídeo/PDF enquanto MEDIA_*_PROVIDER=cloudinary)
# Coolify: configure no serviço do BACKEND (apiclube), NÃO no app cliente/PWA.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Providers de mídia: cloudinary | bunny
# MEDIA_VIDEO_PROVIDER=cloudinary
# MEDIA_DOCUMENT_PROVIDER=cloudinary

# Bunny Stream (vídeos de aula) — quando MEDIA_VIDEO_PROVIDER=bunny
# BUNNY_STREAM_LIBRARY_ID=
# BUNNY_STREAM_API_KEY=
# BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
# BUNNY_STREAM_COLLECTION_ID=
# BUNNY_TRANSCRIPTION_LANG=pt
# Cache Redis dos metadados de vídeo (capítulos, sprites) — requer REDIS_URL
# BUNNY_METADATA_CACHE_TTL_SECONDS=21600

# Bunny Storage (PDFs/ebooks) — quando MEDIA_DOCUMENT_PROVIDER=bunny
# BUNNY_STORAGE_ZONE_NAME=
# BUNNY_STORAGE_API_KEY=
# BUNNY_STORAGE_CDN_HOSTNAME=xxxxx.b-cdn.net
# BUNNY_STORAGE_REGION=de
# BUNNY_STORAGE_DOCUMENTS_PREFIX=ebooks
# URL pública da API (proxy Bunny, webhook UAZAPI → Pusher)
# BACKEND_PUBLIC_URL=https://sua-api.exemplo.com
# Dev local com Cloudflare Tunnel (npm run dev:backend:tunnel):
# CLOUDFLARE_TUNNEL_URL=https://xxxx.trycloudflare.com
# USE_CLOUDFLARE_TUNNEL=false   # desliga prioridade do tunnel no webhook
# DOCUMENT_UPLOAD_MAX_MB=100

# Limite de vídeo no multer (MB). Proxy/nginx precisa aceitar o mesmo tamanho.
# VIDEO_UPLOAD_MAX_SIZE_MB=2048
# Timeout do servidor Node para uploads longos (ms)
# UPLOAD_SERVER_TIMEOUT_MS=1800000

# JWT
JWT_SECRET=
# Cookie de sessão httpOnly — em dev local use false se o login falhar em HTTP
# AUTH_COOKIE_SECURE=false
PORT=3001

# CORS (opcional — se definir, mescla com os domínios padrão de produção)
# CORS_ORIGINS=https://clube.nutrisabellajardim.com.br

# OpenAI (Bella IA) — https://platform.openai.com/api-keys
# Coolify: configure no serviço do BACKEND (apiclube), NÃO no app cliente/PWA.
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_PDF=gpt-4o
# BELLA_DEBUG=true

# UazAPI (WhatsApp) — opcional
UAZAPI_SERVER_URL=
UAZAPI_API_KEY=
# Nome exato da instância na UAZAPI (opcional — use se houver várias instâncias na conta)
UAZAPI_INSTANCE_NAME=
# Secret para validar POST /api/whatsapp/webhook (header x-webhook-secret)
WHATSAPP_WEBHOOK_SECRET=
# Logs dos webhooks (mensagens recebidas): backend/webhook/messages-AAAA-MM-DD.log
# Dev: npm run dev:backend:tunnel (Cloudflare) ou WHATSAPP_DEV_MESSAGE_LOG=false para desligar SSE dev
WHATSAPP_DEV_MESSAGE_LOG=
# Opcional: sobrescreve BACKEND_PUBLIC_URL/api/whatsapp/webhook
# WHATSAPP_WEBHOOK_URL=

# Pusher Channels — tempo real do WhatsApp no painel admin (https://pusher.com)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=sa1

# Chave obrigatória em produção para POST /api/auth/setup/nutricionista (header x-setup-key)
NUTRI_SETUP_KEY=

# Redis — opcional (cache de metadados Bunny Stream)
REDIS_URL=

# Web Push (notificações PWA) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: ou URL do site
VAPID_SUBJECT=mailto:contato@nutrisabellajardim.com.br

# Resend (e-mails transacionais) — https://resend.com/api-keys
# Coolify: configure no serviço do BACKEND (apiclube).
RESEND_API_KEY=
# Cadastro, alertas à nutri, aprovação/reprovação (domínio verificado no Resend)
EMAIL_FROM_CONTACT="Clube Florescer <contato@nutrisabellajardim.com.br>"
# Recuperação de senha e outros automáticos sem resposta
EMAIL_FROM_NOREPLY="Clube Florescer <noreply@nutrisabellajardim.com.br>"
# Legado — se definido, EMAIL_FROM_CONTACT usa este valor como fallback
# EMAIL_FROM="Clube Florescer <contato@nutrisabellajardim.com.br>"
# Destino dos alertas de nova solicitação de cadastro
NUTRI_NOTIFICATION_EMAIL=nutri.isabellajardim@gmail.com
# Validade do link de recuperação de senha (minutos)
PASSWORD_RESET_TTL_MINUTES=10
# Logo nos e-mails (URL pública HTTPS, vertical como no app). Padrão: /icons/logovetorcarregamento.svg
EMAIL_LOGO_URL=https://app.nutrisabellajardim.com.br/icons/logovetorcarregamento.svg
# Logo quadrada BIMI (DNS) — docs/email-bimi-dmarc.md
# BIMI_LOGO_URL=https://app.nutrisabellajardim.com.br/bimi/clube-florescer.svg
# Guia completo BIMI/DMARC: docs/email-bimi-dmarc.md
# Links usados nos e-mails
PATIENT_APP_URL=https://app.nutrisabellajardim.com.br
ADMIN_APP_URL=https://clube.nutrisabellajardim.com.br
# Miniatura do preview de link no WhatsApp (PNG/JPG). Padrão: /pwa/apple-touch-icon.png
# WHATSAPP_LINK_PREVIEW_IMAGE_URL=https://app.nutrisabellajardim.com.br/pwa/apple-touch-icon.png

# Backblaze B2 (Blackbase) — arquivamento permanente de mídias do WhatsApp
# Bucket precisa permitir leitura pública OU use CDN/custom domain em BACKBLAZE_B2_PUBLIC_URL
# BACKBLAZE_B2_KEY_ID=
# BACKBLAZE_B2_APPLICATION_KEY=
# BACKBLAZE_B2_BUCKET_ID=
# BACKBLAZE_B2_BUCKET_NAME=
# URL pública: CDN customizado ou https://f000.backblazeb2.com/file/seu-bucket
# BACKBLAZE_B2_PUBLIC_URL=
# BACKBLAZE_B2_WHATSAPP_PREFIX=whatsapp
