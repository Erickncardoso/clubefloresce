{
  "name": "clube-nutricional-backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "prisma generate && nodemon src/index.ts",
    "build": "tsc",
    "test:integration": "node -r ts-node/register --test \"src/tests/**/*.integration.test.ts\"",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "foods:fetch-tbca": "node scripts/fetch-tbca.mjs",
    "foods:fetch-tbca:probe": "node scripts/fetch-tbca.mjs --probe",
    "foods:build-json": "node scripts/build-food-json.mjs",
    "foods:import": "ts-node scripts/import-foods.ts",
    "foods:update-tbca": "npm run foods:fetch-tbca && npm run foods:build-json && npm run foods:import",
    "foods:seed": "npm run foods:build-json && npm run foods:import",
    "patient:dev": "ts-node src/scripts/ensure-patient-dev.ts",
    "email:check-dns": "node scripts/check-email-dns.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.0",
    "cloudinary": "^1.37.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "pusher": "^5.3.4",
    "resend": "^6.15.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.4.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
