generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  NUTRICIONISTA
  PACIENTE
}

enum UserStatus {
  ATIVO
  INATIVO
  PENDENTE
}

enum UserPlan {
  FREE
  PREMIUM
  PLATINUM
}

enum RegistrationRequestStatus {
  PENDENTE
  APROVADO
  RECUSADO
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model PatientRegistrationRequest {
  id           String                    @id @default(uuid())
  name         String
  email        String
  phone        String?
  message      String?
  passwordHash String?
  status       RegistrationRequestStatus @default(PENDENTE)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([email])
  @@index([status, createdAt])
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  role          Role       @default(PACIENTE)
  avatar        String?
  status        UserStatus @default(ATIVO)
  plan          UserPlan   @default(FREE)
  accessExpiresAt DateTime?
  approvalEmailSentAt DateTime?
  approvalWhatsappSentAt DateTime?
  approvalWhatsappMessage String? @db.Text
  patientGoalsData Json?
  patientProfileData Json?
  onboardingCompletedAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  transactions  Transaction[]

  courses       Course[]
  posts         Post[]
  comments      Comment[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
  lessonProgress LessonProgress[]
  likedComments Comment[]        @relation("CommentLikes")
  likedPosts    Post[]           @relation("PostLikes")
  whatsappChats WhatsappChat[]
  whatsappContactStates WhatsappContactState[]
  whatsappContactDirectory WhatsappContactDirectory?
  whatsappGroupObservedSenders WhatsappGroupObservedSenders[]
  whatsappMediaArchives WhatsappMediaArchive[]
  weeklyCheckIns WeeklyCheckIn[]
  checkInTemplates CheckInTemplate[] @relation("CheckInTemplateAuthor")
  checkInDispatchSchedules CheckInDispatchSchedule[] @relation("CheckInDispatchAuthor")
  checkInResponses CheckInResponse[]
  bellaMessages  BellaMessage[]
  nutritionTarget NutritionTarget?
  foodDiaryEntries FoodDiaryEntry[]
  patientMealPlan PatientMealPlan?
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PatientMealPlan {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  pdfUrl       String?
  title        String?
  patientName  String?
  prescribedAt String?
  plan         Json
  parserSource String   @default("dietbox")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WeeklyCheckIn {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime
  mood      Int
  energy    Int
  adherence Int?
  weightKg  Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([weekStart])
}

model CheckInTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  frequency   String   @default("weekly")
  active      Boolean  @default(true)
  steps       Json
  sortOrder   Int      @default(0)
  isDefault   Boolean  @default(false)
  authorId    String
  author      User     @relation("CheckInTemplateAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  responses   CheckInResponse[]
  dispatchSchedules CheckInDispatchSchedule[]

  @@index([active, sortOrder])
  @@index([authorId])
}

model CheckInDispatchSchedule {
  id          String            @id @default(uuid())
  templateId  String?
  template    CheckInTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  userIds     Json              @default("[]")
  periodDate  String?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String            @default("pending")
  title       String?
  body        String?
  authorId    String
  author      User              @relation("CheckInDispatchAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@index([status, scheduledAt])
  @@index([authorId])
}

model CheckInResponse {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   CheckInTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  periodKey  String
  answers    Json
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([userId, templateId, periodKey])
  @@index([templateId, periodKey])
  @@index([userId])
}

model BellaMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  topic     String   @default("general")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, topic, createdAt])
}

model NutritionTarget {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caloriesKcal Int      @default(2000)
  proteinG     Float    @default(120)
  carbsG       Float    @default(220)
  fatG         Float    @default(65)
  updatedAt    DateTime @updatedAt
}

enum FoodSource {
  TACO
  TBCA
}

model FoodItem {
  id           String     @id @default(uuid())
  source       FoodSource
  sourceCode   String
  name         String
  category     String?
  nutrients    Json
  caloriesKcal Float?
  proteinG     Float?
  carbsG       Float?
  fatG         Float?
  fiberG       Float?
  sodiumMg     Float?
  searchText   String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([source, sourceCode])
  @@index([name])
  @@index([searchText])
  @@index([source])
}

model FoodDiaryEntry {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryDate    DateTime @db.Date
  mealType     String
  mealLabel    String?
  imageUrl     String?
  items        Json
  caloriesKcal Float
  carbsG       Float
  proteinG     Float
  fatG         Float
  createdAt    DateTime @default(now())

  @@index([userId, entryDate])
}

model Course {
  id              String   @id @default(uuid())
  title           String
  description     String?
  thumbnail       String?
  thumbnailMobile String?
  bannerImage     String?
  bannerImageMobile String?
  bannerImagePosition String?
  bannerImageMobilePosition String?
  bannerKicker    String?
  bannerTitle     String?
  bannerSubtitle  String?
  bannerCtaText   String?
  bannerKickerColor String?
  bannerKickerBg String?
  bannerTitleColor String?
  bannerSubtitleColor String?
  bannerCtaBg String?
  bannerCtaColor String?
  bannerSecondaryBtnBg String?
  bannerSecondaryBtnColor String?
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  modules         Module[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  thumbnail   String?
  order       Int      @default(0)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id       String  @id @default(uuid())
  title    String
  videoUrl String
  content  String?
  thumbnail String?
  duration  String?
  order     Int     @default(0)
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  materials     Json?    @default("[]")
  transcription Json?    @default("[]")
  progress      LessonProgress[]
  comments      Comment[]
}

model LessonProgress {
  id         String   @id @default(uuid())
  userId     String
  lessonId   String
  watched    Boolean  @default(false)
  liked      Boolean  @default(false)
  disliked   Boolean  @default(false)
  favorited  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  updatedAt  DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Ebook {
  id          String   @id @default(uuid())
  title       String
  description String
  fileUrl     String
  thumbnail   String?
  createdAt   DateTime @default(now())
}

model Post {
  id        String    @id @default(uuid())
  content   String
  imageUrl  String?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  createdAt  DateTime  @default(now())
  likesCount Int       @default(0)
  likedBy    User[]    @relation("PostLikes")
  comments   Comment[]
}

model Comment {
  id         String   @id @default(uuid())
  content    String
  postId     String?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  lessonId   String?
  lesson     Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  likesCount Int      @default(0)
  likedBy    User[]   @relation("CommentLikes")
  createdAt  DateTime @default(now())
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   @default("general")
  title      String
  body       String
  actionPath String?
  sourceKey  String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, sourceKey])
  @@index([userId, read, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  status    String   @default("PAID") // PAID, PENDING, CANCELLED
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model WhatsappChat {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatJid         String
  name            String?
  pushName        String?
  avatarUrl       String?
  isGroup         Boolean  @default(false)
  lastMessage     String?
  lastMessageTime BigInt?
  unreadCount     Int      @default(0)
  raw             Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, chatJid])
  @@index([userId, lastMessageTime])
}

// Diretório de contatos salvos: { jid/phone: nome } — fonte de nomes no chat.
// Um registro por usuário, atualizado a cada sync com UAZAPI /contacts/list.
model WhatsappContactDirectory {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json     // { "55119...@s.whatsapp.net": "Nome Salvo", ... }
  updatedAt DateTime @updatedAt
}

// Nomes aprendidos no chat de grupo (LID/JID → display), persistidos para histórico reabrir com rótulos.
model WhatsappGroupObservedSenders {
  id        String   @id @default(uuid())
  userId    String
  groupJid  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json     // { "....@lid": "Maria", "5511...@s.whatsapp.net": "João", ... }
  updatedAt DateTime @updatedAt

  @@unique([userId, groupJid])
  @@index([userId])
}

model WhatsappContactState {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactJid      String
  isSaved         Boolean   @default(false)
  isBusiness      Boolean   @default(false)
  phone           String?
  displayName     String?
  avatarUrl       String?
  details         Json?
  detailsSyncedAt DateTime?
  lastCheckedAt   DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, contactJid])
  @@index([userId, updatedAt])
}

// Mídia do WhatsApp arquivada no Backblaze B2 (links da UAZAPI expiram).
model WhatsappMediaArchive {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId  String
  chatJid    String?
  mimeType   String?
  storageKey String
  publicUrl  String
  sourceUrl  String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, messageId])
  @@index([userId, chatJid])
}
