NUXT_PUBLIC_MOBILE_APP=true

# Dev local — proxy do Vite em /api → backend em :3001
# NÃO defina NUXT_PUBLIC_API_BASE=/api no Coolify/produção (o build usa a API de produção automaticamente).
NUXT_PUBLIC_API_BASE=/api

# Produção (opcional — padrão do Dockerfile/build):
# NUXT_PUBLIC_API_BASE=https://apiclube.nutrisabellajardim.com.br/api
