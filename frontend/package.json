{
  "name": "clube-nutricional-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:paciente": "cross-env NUXT_PUBLIC_MOBILE_APP=true nuxt build",
    "dev": "nuxt dev --port 3000",
    "dev:paciente": "node scripts/dev-paciente.mjs",
    "dev:mobile": "npm run dev:paciente",
    "generate": "nuxt generate",
    "generate:paciente": "cross-env NUXT_PUBLIC_MOBILE_APP=true nuxt generate",
    "generate:mobile": "npm run generate:paciente",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "preview": "nuxt preview",
    "preview:paciente": "cross-env NUXT_PUBLIC_MOBILE_APP=true nuxt preview",
    "test": "node --test \"tests/**/*.test.js\"",
    "postinstall": "nuxt prepare",
    "prepare:mobile": "cross-env NUXT_PUBLIC_MOBILE_APP=true nuxt prepare"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@fontsource/metropolis": "^5.2.5",
    "@lottiefiles/dotlottie-vue": "^0.11.15",
    "@pinia/nuxt": "^0.5.0",
    "emoji-mart": "^5.6.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^3.12.0",
    "pdfjs-dist": "^5.6.205",
    "pinia": "^2.1.0",
    "plyr": "^3.8.4",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@vite-pwa/nuxt": "^1.1.1",
    "cross-env": "^7.0.3",
    "sharp": "^0.34.5"
  }
}
